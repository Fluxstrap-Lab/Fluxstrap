<ui:UiPage x:Class="Fluxstrap.UI.Elements.Settings.Pages.OverlayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:Fluxstrap.UI.Elements.Controls"
      xmlns:dmodels="clr-namespace:Fluxstrap.UI.ViewModels.Settings"
      xmlns:resources="clr-namespace:Fluxstrap.Resources"
      d:DataContext="{d:DesignInstance dmodels:OverlayViewModel, IsDesignTimeCreatable=True}"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="800"
      Title="OverlayPage"
      Scrollable="True">
    <StackPanel Margin="0,0,14,14">
        <TextBlock Text="{x:Static resources:Strings.Menu_Overlay_Description}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16" />

        <controls:OptionControl
            Header="{x:Static resources:Strings.Menu_Overlay_EnableOverlay}"
            Description="{x:Static resources:Strings.Menu_Overlay_EnableOverlay_Description}">
            <ui:ToggleSwitch IsChecked="{Binding OverlayEnabled, Mode=TwoWay}" />
        </controls:OptionControl>

        <ui:CardExpander Margin="0,8,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <StackPanel>
                    <TextBlock FontSize="14" Text="{x:Static resources:Strings.Menu_Overlay_DisplayOptions}" />
                    <TextBlock FontSize="12" Text="{x:Static resources:Strings.Menu_Overlay_DisplayOptions_Description}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </ui:CardExpander.Header>
            <StackPanel>
                <controls:OptionControl Header="{x:Static resources:Strings.Menu_Overlay_ShowFps}">
                    <ui:ToggleSwitch IsChecked="{Binding OverlayShowFps, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl Header="{x:Static resources:Strings.Menu_Overlay_ShowPing}">
                    <ui:ToggleSwitch IsChecked="{Binding OverlayShowPing, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl Header="{x:Static resources:Strings.Menu_Overlay_ShowRam}">
                    <ui:ToggleSwitch IsChecked="{Binding OverlayShowRam, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl Header="{x:Static resources:Strings.Menu_Overlay_ShowServer}">
                    <ui:ToggleSwitch IsChecked="{Binding OverlayShowServer, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl Header="{x:Static resources:Strings.Menu_Overlay_ShowFriends}">
                    <ui:ToggleSwitch IsChecked="{Binding OverlayShowFriends, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl Header="{x:Static resources:Strings.Menu_Overlay_ShowCpu}">
                    <ui:ToggleSwitch IsChecked="{Binding OverlayShowCpu, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl Header="{x:Static resources:Strings.Menu_Overlay_ShowGpu}">
                    <ui:ToggleSwitch IsChecked="{Binding OverlayShowGpu, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl Header="{x:Static resources:Strings.Menu_Overlay_ShowVolume}">
                    <ui:ToggleSwitch IsChecked="{Binding OverlayShowVolume, Mode=TwoWay}" />
                </controls:OptionControl>
                <controls:OptionControl Header="{x:Static resources:Strings.Menu_Overlay_ShowGraph}">
                    <ui:ToggleSwitch IsChecked="{Binding OverlayShowGraph, Mode=TwoWay}" />
                </controls:OptionControl>
            </StackPanel>
        </ui:CardExpander>

        <ui:CardExpander Margin="0,8,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <StackPanel>
                    <TextBlock FontSize="14" Text="{x:Static resources:Strings.Menu_Overlay_PositionAppearance}" />
                    <TextBlock FontSize="12" Text="{x:Static resources:Strings.Menu_Overlay_PositionAppearance_Description}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </ui:CardExpander.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static resources:Strings.Menu_Overlay_Position}" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox Grid.Row="0" Grid.Column="1" Width="200" Padding="10,5,10,5" 
                          ItemsSource="{Binding PositionOptions, Mode=OneTime}" 
                          Text="{Binding OverlayPosition, Mode=TwoWay}" />
                          
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static resources:Strings.Menu_Overlay_Opacity}" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <Slider Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Minimum="0.1" Maximum="1.0" 
                        Value="{Binding OverlayOpacity, Mode=TwoWay}" TickFrequency="0.1" IsSnapToTickEnabled="True" Width="200" HorizontalAlignment="Left" />
                        
                <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static resources:Strings.Menu_Overlay_ToggleHotkey}" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:TextBox Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Text="{Binding OverlayToggleHotkey, Mode=TwoWay}" Width="200" HorizontalAlignment="Left" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static resources:Strings.Menu_Overlay_AccentColor}" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Width="200" Padding="10,5,10,5" HorizontalAlignment="Left"
                          ItemsSource="{Binding AccentColorOptions, Mode=OneTime}"
                          Text="{Binding OverlayAccentColor, Mode=TwoWay}" />
            </Grid>
        </ui:CardExpander>

        <ui:Card Margin="0,12,0,0" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.Menu_Overlay_TestOverlay}" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="{x:Static resources:Strings.Menu_Overlay_TestOverlay_Description}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>
                <ui:Button Grid.Column="1" Icon="Play24" Content="{x:Static resources:Strings.Menu_Overlay_ToggleNow}" Command="{Binding ToggleOverlayNowCommand}" />
            </Grid>
        </ui:Card>
    </StackPanel>
</ui:UiPage>