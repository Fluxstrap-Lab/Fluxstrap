<ui:UiPage x:Class="Fluxstrap.UI.Elements.Settings.Pages.BehaviourPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:Fluxstrap.UI.Elements.Settings.Pages"
      xmlns:controls="clr-namespace:Fluxstrap.UI.Elements.Controls"
      xmlns:models="clr-namespace:Fluxstrap.UI.ViewModels.Settings"
      xmlns:resources="clr-namespace:Fluxstrap.Resources"
      d:DataContext="{d:DesignInstance Type=models:BehaviourViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="BehaviourPage"
      Scrollable="True">

    <StackPanel Margin="0,0,14,14">
        <TextBlock Margin="0,0,0,8" Text="{x:Static resources:Strings.Menu_Behaviour_Description}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <controls:OptionControl 
            Header="{x:Static resources:Strings.Menu_Behaviour_ConfirmLaunches_Title}"
            Description="{x:Static resources:Strings.Menu_Behaviour_ConfirmLaunches_Description}">
            <ui:ToggleSwitch IsChecked="{Binding ConfirmLaunches, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl 
            Header="{x:Static resources:Strings.Menu_Behaviour_BackgroundUpdates_Title}"
            Description="{x:Static resources:Strings.Menu_Behaviour_BackgroundUpdates_Description}">
            <ui:ToggleSwitch IsChecked="{Binding BackgroundUpdates, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl 
            Header="{x:Static resources:Strings.Menu_Behaviour_ForceRobloxReinstall_Title}"
            Description="{x:Static resources:Strings.Menu_Behaviour_ForceRobloxReinstall_Description}">
            <controls:OptionControl.Style>
                <Style TargetType="controls:OptionControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRobloxInstallationMissing, Mode=OneTime}" Value="True">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:OptionControl.Style>
            <ui:ToggleSwitch IsChecked="{Binding ForceRobloxReinstallation, Mode=TwoWay}" />
        </controls:OptionControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="Performance" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Optimize Roblox process resource usage on launch" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Optimize Roblox"
            Description="Apply performance optimizations when launching Roblox">
            <ui:ToggleSwitch IsChecked="{Binding OptimizeRoblox, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="CPU Core Limit"
            Description="Maximum CPU cores for Roblox (0 = no limit)">
            <ui:NumberBox Value="{Binding MaxCpuCores, Mode=TwoWay}" Min="0" Width="120" IntegersOnly="True" SpinButtonsEnabled="True" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Memory Cleaner"
            Description="Reduce Roblox memory usage by emptying working set and setting below-normal priority">
            <ui:ToggleSwitch IsChecked="{Binding MemoryCleaner, Mode=TwoWay}" />
        </controls:OptionControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="FPS Unlocker" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Remove the 60 FPS cap for a smoother experience" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Unlock FPS"
            Description="Set a custom framerate cap (requires restart)">
            <ui:ToggleSwitch IsChecked="{Binding UnlockFPS, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="FPS Cap"
            Description="Maximum framerate (30-999)">
            <ui:NumberBox Value="{Binding FPSCap, Mode=TwoWay}" Min="30" Max="999" Width="120" IntegersOnly="True" SpinButtonsEnabled="True" />
        </controls:OptionControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="Graphics Quality Override" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Force a specific graphics quality level (1-21)" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Force Graphics Quality"
            Description="Override Roblox's automatic quality setting">
            <ui:ToggleSwitch IsChecked="{Binding ForceGraphicsQuality, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Quality Level"
            Description="Graphics quality level (1 = lowest, 21 = highest)">
            <ui:NumberBox Value="{Binding GraphicsQualityLevel, Mode=TwoWay}" Min="1" Max="21" Width="120" IntegersOnly="True" SpinButtonsEnabled="True" />
        </controls:OptionControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="Session Tracking" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Track play time per game session" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Track Play Time"
            Description="Record how long you play each game session">
            <ui:ToggleSwitch IsChecked="{Binding TrackPlayTime, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Session Stats"
            Description="Today / All time / Current session"
            Visibility="{Binding ShowPlayTimeStats, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding TodayPlayTime, StringFormat='Today: {0}'}" FontWeight="Medium" />
                <TextBlock Text="{Binding AllTimePlayTime, StringFormat='All Time: {0}'}" />
                <TextBlock Text="{Binding CurrentSessionTime, StringFormat='Current: {0}'}" />
                <TextBlock Text="{Binding SessionCount, StringFormat='Total Sessions: {0}'}" />
            </StackPanel>
        </controls:OptionControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="Cache Maintenance" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Manage Roblox cache files to free up disk space" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Auto-clean HTTP Cache on exit"
            Description="Automatically delete Roblox HTTP cache when the game closes">
            <ui:ToggleSwitch IsChecked="{Binding AutoCleanRobloxCache, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Current Cache Size"
            Description="{Binding RobloxCacheSize, Mode=OneWay}">
            <ui:Button Content="Clean Now" Command="{Binding CleanRobloxCacheCommand}" />
        </controls:OptionControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="Crash Reports" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Recent Roblox crash dump files" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Open Crash Dumps Folder"
            Description="Browse all crash dump files in Explorer">
            <ui:Button Content="Open Folder" Command="{Binding OpenAllCrashDumpsFolderCommand}" />
        </controls:OptionControl>

        <ItemsControl ItemsSource="{Binding CrashDumps}" Margin="0,8,0,0" Visibility="{Binding HasCrashDumps, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:CardAction Margin="0,0,0,4" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding FileName}" FontWeight="Medium" />
                                <TextBlock Text="{Binding FileSize, StringFormat='Size: {0}'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding CreatedAt, StringFormat='Date: {0:yyyy-MM-dd HH:mm}'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Content="Open" Command="{Binding DataContext.OpenCrashDumpFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Margin="0,0,8,0" />
                                <ui:Button Content="Delete" Command="{Binding DataContext.DeleteCrashDumpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                            </StackPanel>
                        </Grid>
                    </ui:CardAction>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="Quick Launch" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Save favorite places and launch them directly" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Add Favorite"
            Description="Enter a place ID and name to add to your favorites">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Margin="0,0,4,0" Text="{Binding NewFavoritePlaceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Place ID" Padding="10,5" />
                    <ui:TextBox Grid.Column="1" Margin="4,0,4,0" Text="{Binding NewFavoritePlaceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Name" Padding="10,5" />
                    <ui:Button Grid.Column="2" Content="Add" Command="{Binding AddFavoritePlaceCommand}" />
                </Grid>
            </StackPanel>
        </controls:OptionControl>

        <ItemsControl ItemsSource="{Binding FavoritePlaces}" Margin="0,8,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:CardAction Margin="0,0,0,4" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="Medium" />
                                <TextBlock Text="{Binding PlaceId, StringFormat='Place ID: {0}'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Content="Launch" Command="{Binding DataContext.LaunchFavoritePlaceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Margin="0,0,8,0" Appearance="Success" />
                                <ui:Button Content="Remove" Command="{Binding DataContext.RemoveFavoritePlaceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Appearance="Danger" />
                            </StackPanel>
                        </Grid>
                    </ui:CardAction>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="Crash Recovery &amp; Launch" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Auto-relaunch on crash and custom launch options" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Auto-Relaunch on Crash"
            Description="Automatically restart Roblox if it crashes">
            <ui:ToggleSwitch IsChecked="{Binding AutoRelaunchOnCrash, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Auto-Repair on Crash Loop"
            Description="Auto-repair Roblox installation after 3 consecutive crashes">
            <ui:ToggleSwitch IsChecked="{Binding AutoRepairOnCrashLoop, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Custom Launch Arguments"
            Description="Extra command-line arguments to pass to Roblox">
            <ui:TextBox Text="{Binding CustomLaunchArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="-a 123456 -t ticket" Padding="10,5" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Resource Monitor"
            Description="Show Roblox CPU/Memory usage in tray icon tooltip">
            <ui:ToggleSwitch IsChecked="{Binding ShowResourceMonitor, Mode=TwoWay}" />
        </controls:OptionControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="Anti-AFK &amp; Rejoin" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Prevent idle kicks and auto-rejoin on disconnect" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Anti-AFK"
            Description="Prevent Roblox from kicking you for inactivity by simulating minimal input every 30 seconds">
            <ui:ToggleSwitch IsChecked="{Binding AntiAFK, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Auto-Rejoin on Disconnect"
            Description="Automatically rejoin the same server when disconnected (uses JobId)">
            <ui:ToggleSwitch IsChecked="{Binding AutoRejoinOnDisconnect, Mode=TwoWay}" />
        </controls:OptionControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="Per-Game Profiles" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Auto-apply settings (FPS cap, graphics) when joining specific games" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Add Game Profile"
            Description="Enter Universe ID and game name">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Margin="0,0,4,0" Text="{Binding NewGameProfileUniverseId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Universe ID" Padding="10,5" />
                    <ui:TextBox Grid.Column="1" Margin="4,0,4,0" Text="{Binding NewGameProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Game Name" Padding="10,5" />
                    <ui:Button Grid.Column="2" Content="Add" Command="{Binding AddGameProfileCommand}" />
                </Grid>
            </StackPanel>
        </controls:OptionControl>

        <ItemsControl ItemsSource="{Binding GameProfiles}" Margin="0,8,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:CardAction Margin="0,0,0,4" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding GameName}" FontWeight="Medium" />
                                <TextBlock Text="{Binding UniverseId, StringFormat='Universe ID: {0}'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding FpsCap, StringFormat='FPS: {0}'}" Margin="0,0,12,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding GraphicsQualityLevel, StringFormat='Quality: {0}'}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:Button Content="Remove" Command="{Binding DataContext.RemoveGameProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Appearance="Danger" />
                            </StackPanel>
                        </Grid>
                    </ui:CardAction>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="128" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock Text="System &amp; Hotkeys" FontSize="20" FontWeight="Medium" VerticalAlignment="Bottom" />
                <TextBlock Text="Launch on startup, global hotkeys, and notification preferences" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <controls:OptionControl
            Header="Launch on Windows Startup"
            Description="Automatically start Fluxstrap when you log into Windows">
            <ui:ToggleSwitch IsChecked="{Binding LaunchOnStartup, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Global Hotkeys"
            Description="Ctrl+Shift+R = Rejoin, Ctrl+Shift+K = Kill Roblox, Ctrl+Shift+F = Toggle FPS Unlock (requires restart)">
            <ui:ToggleSwitch IsChecked="{Binding EnableGlobalHotkeys, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Do Not Disturb"
            Description="Suppress tray notifications while playing a game">
            <ui:ToggleSwitch IsChecked="{Binding DNDDuringGameplay, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Streaming Mode"
            Description="Hide tray details, suppress all notifications, and hide Discord RPC in one click">
            <ui:ToggleSwitch IsChecked="{Binding StreamingMode, Mode=TwoWay}" />
        </controls:OptionControl>
    </StackPanel>
</ui:UiPage>
